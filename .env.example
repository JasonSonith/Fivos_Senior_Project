# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# ── Database ──────────────────────────────────────────────────────────────────
FIVOS_MONGO_URI=mongodb://localhost:27017/fivos

# ── App ───────────────────────────────────────────────────────────────────────
FIVOS_SECRET_KEY=change-me-to-a-random-string

# ── Manufacturer credentials (only needed for authenticated portals) ──────────
# Naming convention: FIVOS_{MANUFACTURER}_{FIELD}
# FIVOS_MEDTRONIC_USERNAME=
# FIVOS_MEDTRONIC_PASSWORD=
# FIVOS_ABBOTT_USERNAME=
# FIVOS_ABBOTT_PASSWORD=
# FIVOS_BOSTON_SCIENTIFIC_USERNAME=
# FIVOS_BOSTON_SCIENTIFIC_PASSWORD=
# FIVOS_GORE_USERNAME=
# FIVOS_GORE_PASSWORD=
# FIVOS_COOK_USERNAME=
# FIVOS_COOK_PASSWORD=
# FIVOS_SHOCKWAVE_USERNAME=
# FIVOS_SHOCKWAVE_PASSWORD=
# FIVOS_CORDIS_USERNAME=
# FIVOS_CORDIS_PASSWORD=
# FIVOS_TERUMO_USERNAME=
# FIVOS_TERUMO_PASSWORD=
