# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# ── Database ──────────────────────────────────────────────────────────────────
FIVOS_MONGO_URI=change-me

# ── Groq API (free: https://console.groq.com/keys) ───────────────────────────
# If set, Groq is used for extraction (fast, cloud). If empty, falls back to local Ollama.
GROQ_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
FIVOS_SECRET_KEY=change-me-to-a-random-string
