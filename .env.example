# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# ── Database ──────────────────────────────────────────────────────────────────
# Full MongoDB connection URI (Atlas: mongodb+srv://user:pass@host/?appName=Fivos)
FIVOS_MONGO_URI=change-me
# These are used to initialize the local mongo:7 container on first boot.
# Set them to the same values as your Atlas username/password (or any strong credentials for local dev).
MONGO_INITDB_ROOT_USERNAME=fivos
MONGO_INITDB_ROOT_PASSWORD=change-me-to-a-strong-password

# ── LLM APIs (fallback chain: Groq → NVIDIA → local qwen2.5:3b) ─────────────
# For client install: Jason will email you a filled .env — paste it here.
# For devs / future swap: get your own free keys at
#   Groq:   https://console.groq.com/keys
#   NVIDIA: https://build.nvidia.com → profile → API Keys → Generate
# If both are empty, the system falls back to local Ollama only (slow on CPU).
GROQ_API_KEY=
NVIDIA_API_KEY=

AUTH_SECRET_KEY=fivos-super-secret-key-2026-change-this
